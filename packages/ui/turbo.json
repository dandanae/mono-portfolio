{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:styles", "build:components"],
      "env": ["NEXT_PUBLIC_API_KEY", "NEXT_PUBLIC_AUTH_DOMAIN", "NEXT_PUBLIC_PROJECT_ID", "NEXT_PUBLIC_STORAGE_BUCKET", "NEXT_PUBLIC_MESSAGING_SENDER_ID", "NEXT_PUBLIC_APP_ID", "NEXT_PUBLIC_MEASUREMENT_ID"]
    },
    "build:styles": {
      "outputs": ["dist/**"]
    },
    "build:components": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "with": ["dev:styles", "dev:components"]
    },
    "dev:styles": {
      "cache": false,
      "persistent": true
    },
    "dev:components": {
      "cache": false,
      "persistent": true
    }
  }
}
